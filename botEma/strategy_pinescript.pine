//@version=5
strategy("EMA 20 / SMA 50 Cross Strategy", overlay=true, initial_capital=10000, default_qty_type=strategy.percent_of_equity, default_qty_value=100, commission_type=strategy.commission.percent, commission_value=0.1)

// ============================================
// PARAMÈTRES DE LA STRATÉGIE
// ============================================

// Indicateurs
ema_fast_length = input.int(20, "EMA Rapide", minval=1)
sma_slow_length = input.int(50, "SMA Lente", minval=1)
atr_period = input.int(14, "Période ATR", minval=1)
atr_multiplier = input.float(0.5, "Multiplicateur ATR (filtre)", minval=0.1, step=0.1)
atr_lookback = input.int(20, "Lookback ATR (moyenne)", minval=1)
atr_sl_multiplier = input.float(1.5, "Multiplicateur ATR pour SL", minval=0.1, step=0.1)

// Risk/Reward adaptatif
sma_slope_min = input.float(0.00003, "Pente minimale SMA (pour R:R)", minval=0.0, step=0.00001)
rr_ratio_flat = input.float(1.0, "R:R si SMA plate (1:1)", minval=0.5, step=0.1)
rr_ratio_trending = input.float(1.5, "R:R si SMA penche (1:1.5)", minval=0.5, step=0.1)

// Filtres
use_h1_trend_filter = input.bool(true, "Activer filtre tendance H1")
use_atr_filter = input.bool(true, "Activer filtre ATR")
use_atr_sl = input.bool(true, "Utiliser ATR pour Stop Loss")
max_sl_distance_pct = input.float(5.0, "Distance max SL (%)", minval=1.0, step=0.5)

// Sessions de trading (UTC)
use_session_filter = input.bool(true, "Activer filtre sessions")
session_asia_start = input.int(0, "Session ASIA début (heure UTC)", minval=0, maxval=23)
session_asia_end = input.int(8, "Session ASIA fin (heure UTC)", minval=0, maxval=23)
session_europe_start = input.int(8, "Session EUROPE début (heure UTC)", minval=0, maxval=23)
session_europe_end = input.int(14, "Session EUROPE fin (heure UTC)", minval=0, maxval=23)
session_us_start = input.int(14, "Session US début (heure UTC)", minval=0, maxval=23)
session_us_end = input.int(21, "Session US fin (heure UTC)", minval=0, maxval=23)

// Protection contre sur-trading
min_bars_between_trades = input.int(5, "Bougies min entre mêmes setups", minval=1)

// ============================================
// CALCUL DES INDICATEURS (TIMEFRAME ACTUEL = M5)
// ============================================

// EMA 20 et SMA 50 sur le timeframe actuel (M5)
ema_fast = ta.ema(close, ema_fast_length)
sma_slow = ta.sma(close, sma_slow_length)

// ATR
atr = ta.atr(atr_period)
atr_avg = ta.sma(atr, atr_lookback)

// Pente de la SMA 50 (pour déterminer si elle est plate ou penche)
sma_slope = math.abs(sma_slow - sma_slow[1])
sma_slope_pct = sma_slope / sma_slow
is_sma_flat = sma_slope_pct < sma_slope_min

// R:R adaptatif selon pente SMA
rr_ratio = is_sma_flat ? rr_ratio_flat : rr_ratio_trending

// ============================================
// DONNÉES H1 (POUR FILTRE DE TENDANCE)
// ============================================

// Récupérer les données H1 pour l'analyse de tendance
// Utiliser request.security pour récupérer les clôtures H1
h1_close = request.security(syminfo.tickerid, "60", close, lookahead=barmerge.lookahead_off)

// Les 3 dernières bougies H1: utiliser les valeurs historiques de h1_close
h1_price_0 = h1_close[2]  // Première des 3 (la plus ancienne)
h1_price_1 = h1_close[1]  // Deuxième
h1_price_2 = h1_close     // Dernière (actuelle)

// Compter les hausses et baisses entre les 3 bougies
h1_rise_0_to_1 = h1_price_1 > h1_price_0  // Transition de bougie 0 à 1
h1_rise_1_to_2 = h1_price_2 > h1_price_1  // Transition de bougie 1 à 2
h1_fall_0_to_1 = h1_price_1 < h1_price_0  // Transition de bougie 0 à 1
h1_fall_1_to_2 = h1_price_2 < h1_price_1  // Transition de bougie 1 à 2

// Compter le nombre de hausses/baisses
h1_rises_count = (h1_rise_0_to_1 ? 1 : 0) + (h1_rise_1_to_2 ? 1 : 0)
h1_falls_count = (h1_fall_0_to_1 ? 1 : 0) + (h1_fall_1_to_2 ? 1 : 0)

// Tendance H1 haussière: prix final (2) > prix initial (0) ET au moins 2 hausses
h1_bullish = (h1_price_2 > h1_price_0) and (h1_rises_count >= 2)

// Tendance H1 baissière: prix final (2) < prix initial (0) ET au moins 2 baisses
h1_bearish = (h1_price_2 < h1_price_0) and (h1_falls_count >= 2)

// ============================================
// FILTRES
// ============================================

// Filtre ATR: éviter les marchés compressés
atr_filter_ok = not use_atr_filter or (atr >= (atr_avg * atr_multiplier))

// Filtre H1: ne trader que dans le sens de la tendance H1
h1_filter_long_ok = not use_h1_trend_filter or h1_bullish
h1_filter_short_ok = not use_h1_trend_filter or h1_bearish

// Filtre session de trading
get_session() =>
    hour_utc = hour(time, "UTC")
    if hour_utc >= session_asia_start and hour_utc < session_asia_end
        "ASIA"
    else if hour_utc >= session_europe_start and hour_utc < session_europe_end
        "EUROPE"
    else if hour_utc >= session_us_start and hour_utc < session_us_end
        "US"
    else
        "OFF_HOURS"

current_session = get_session()
session_filter_ok = not use_session_filter or (current_session != "OFF_HOURS")

// ============================================
// CONDITIONS D'ENTRÉE
// ============================================

// Croisement LONG: EMA 20 croise au-dessus de SMA 50
ema_above_sma = ema_fast > sma_slow
ema_below_sma_prev = ema_fast[1] <= sma_slow[1]
long_cross = ema_above_sma and ema_below_sma_prev

// Croisement SHORT: EMA 20 croise en-dessous de SMA 50
ema_below_sma = ema_fast < sma_slow
ema_above_sma_prev = ema_fast[1] >= sma_slow[1]
short_cross = ema_below_sma and ema_above_sma_prev

// Conditions d'entrée complètes
long_entry = long_cross and atr_filter_ok and h1_filter_long_ok and session_filter_ok
short_entry = short_cross and atr_filter_ok and h1_filter_short_ok and session_filter_ok

// ============================================
// CALCUL STOP LOSS ET TAKE PROFIT
// ============================================

// Stop Loss basé sur ATR ou dernier swing
calculate_sl_long() =>
    sl_atr = close - (atr * atr_sl_multiplier)
    sl_swing = ta.lowest(low, 10) - (atr * 0.1)  // Dernier swing bas avec buffer
    use_atr_sl ? sl_atr : sl_swing

calculate_sl_short() =>
    sl_atr = close + (atr * atr_sl_multiplier)
    sl_swing = ta.highest(high, 10) + (atr * 0.1)  // Dernier swing haut avec buffer
    use_atr_sl ? sl_atr : sl_swing

// Validation SL: max 5% du prix d'entrée
validate_sl_long(sl_price, entry_price) =>
    sl_distance_pct = math.abs(entry_price - sl_price) / entry_price * 100
    if sl_distance_pct > max_sl_distance_pct
        entry_price - (entry_price * max_sl_distance_pct / 100)  // Ajuster à 5%
    else
        sl_price

validate_sl_short(sl_price, entry_price) =>
    sl_distance_pct = math.abs(sl_price - entry_price) / entry_price * 100
    if sl_distance_pct > max_sl_distance_pct
        entry_price + (entry_price * max_sl_distance_pct / 100)  // Ajuster à 5%
    else
        sl_price

// Take Profit basé sur R:R adaptatif
calculate_tp_long(entry_price, sl_price) =>
    stop_distance = entry_price - sl_price
    entry_price + (stop_distance * rr_ratio)

calculate_tp_short(entry_price, sl_price) =>
    stop_distance = sl_price - entry_price
    entry_price - (stop_distance * rr_ratio)

// ============================================
// PROTECTION CONTRE SUR-TRADING
// ============================================

var int last_long_bar = 0
var int last_short_bar = 0

can_trade_long = bar_index - last_long_bar >= min_bars_between_trades
can_trade_short = bar_index - last_short_bar >= min_bars_between_trades

// ============================================
// CALCUL SL/TP À CHAQUE BARRE (pour cohérence)
// ============================================

// Calculer les SL et TP à chaque barre (requis par PineScript)
sl_long_raw = calculate_sl_long()
sl_short_raw = calculate_sl_short()

sl_long = validate_sl_long(sl_long_raw, close)
sl_short = validate_sl_short(sl_short_raw, close)

tp_long = calculate_tp_long(close, sl_long)
tp_short = calculate_tp_short(close, sl_short)

// ============================================
// EXÉCUTION DES TRADES
// ============================================

if long_entry and can_trade_long
    strategy.entry("LONG", strategy.long, comment="EMA20/SMA50 Cross")
    strategy.exit("LONG Exit", "LONG", stop=sl_long, limit=tp_long, comment="SL/TP")
    last_long_bar := bar_index

if short_entry and can_trade_short
    strategy.entry("SHORT", strategy.short, comment="EMA20/SMA50 Cross")
    strategy.exit("SHORT Exit", "SHORT", stop=sl_short, limit=tp_short, comment="SL/TP")
    last_short_bar := bar_index

// ============================================
// AFFICHAGE SUR LE GRAPHE
// ============================================

// Afficher EMA et SMA
plot(ema_fast, "EMA 20", color=color.blue, linewidth=2)
plot(sma_slow, "SMA 50", color=color.orange, linewidth=2)

// Afficher les signaux d'entrée
plotshape(long_entry, "Signal LONG", shape.triangleup, location.belowbar, color.green, size=size.small)
plotshape(short_entry, "Signal SHORT", shape.triangledown, location.abovebar, color.red, size=size.small)

// Afficher les informations de tendance H1
bgcolor(h1_bullish ? color.new(color.green, 95) : na, title="Tendance H1 Haussier")
bgcolor(h1_bearish ? color.new(color.red, 95) : na, title="Tendance H1 Baissier")

// Tableau d'information
var table info_table = table.new(position.top_right, 2, 8, bgcolor=color.white, border_width=1)

if barstate.islast
    table.cell(info_table, 0, 0, "Stratégie", text_color=color.black, bgcolor=color.gray)
    table.cell(info_table, 1, 0, "EMA20/SMA50", text_color=color.black)
    
    table.cell(info_table, 0, 1, "EMA 20", text_color=color.black)
    table.cell(info_table, 1, 1, str.tostring(ema_fast, "#.##"), text_color=color.blue)
    
    table.cell(info_table, 0, 2, "SMA 50", text_color=color.black)
    table.cell(info_table, 1, 2, str.tostring(sma_slow, "#.##"), text_color=color.orange)
    
    table.cell(info_table, 0, 3, "R:R", text_color=color.black)
    table.cell(info_table, 1, 3, "1:" + str.tostring(rr_ratio, "#.#"), text_color=is_sma_flat ? color.gray : color.blue)
    
    table.cell(info_table, 0, 4, "H1 Tendance", text_color=color.black)
    h1_trend_text = h1_bullish ? "HAUSSIER" : h1_bearish ? "BAISSIER" : "NEUTRE"
    h1_trend_color = h1_bullish ? color.green : h1_bearish ? color.red : color.gray
    table.cell(info_table, 1, 4, h1_trend_text, text_color=h1_trend_color)
    
    table.cell(info_table, 0, 5, "Session", text_color=color.black)
    table.cell(info_table, 1, 5, current_session, text_color=color.black)
    
    table.cell(info_table, 0, 6, "ATR Filter", text_color=color.black)
    table.cell(info_table, 1, 6, atr_filter_ok ? "OK" : "BLOQUÉ", text_color=atr_filter_ok ? color.green : color.red)
    
    table.cell(info_table, 0, 7, "Position", text_color=color.black)
    pos_text = strategy.position_size > 0 ? "LONG" : strategy.position_size < 0 ? "SHORT" : "AUCUNE"
    pos_color = strategy.position_size > 0 ? color.green : strategy.position_size < 0 ? color.red : color.gray
    table.cell(info_table, 1, 7, pos_text, text_color=pos_color)
